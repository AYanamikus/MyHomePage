---
import '../styles.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
const { title = 'Combat Design Portfolio', description = 'Private-preview portfolio for game combat design and technical design recruitment evaluation.' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <NoticeBanner />
    <Navbar />
    <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
