---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/documents', label: 'Documents' },
  { href: '/contact', label: 'Contact' }
];
---
<header class="border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <a href="/" class="text-lg font-bold tracking-tight text-slate-950">MyHomePage</a>
    <div class="flex flex-wrap items-center gap-3 text-sm font-medium text-slate-600">
      {links.map((link) => (
        <a class="rounded-full px-3 py-1.5 hover:bg-slate-100 hover:text-brand" href={link.href}>{link.label}</a>
      ))}
    </div>
  </nav>
</header>
