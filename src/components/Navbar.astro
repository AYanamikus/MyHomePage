---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/documents', label: 'Documents' },
  { href: '/contact', label: 'Contact' }
];
---
<header class="sticky top-0 z-20 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8" aria-label="Main navigation">
    <a href="/" class="text-lg font-black tracking-tight text-slate-950">Combat Design Portfolio</a>
    <div class="flex flex-wrap items-center gap-2 text-sm font-medium text-slate-600">
      {links.map((link) => <a class="rounded-full px-3 py-1.5 hover:bg-slate-100 hover:text-blue-700" href={link.href}>{link.label}</a>)}
    </div>
  </nav>
</header>
