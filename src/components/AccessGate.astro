---
import { ACCESS_CODE, ACCESS_STORAGE_KEY } from '../config/access';
const { code = ACCESS_CODE } = Astro.props;
---
<section class="rounded-3xl border border-blue-100 bg-white p-6 shadow-sm" data-access-gate data-access-code={code} data-storage-key={ACCESS_STORAGE_KEY}>
  <div data-locked>
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-600">Restricted content</p>
    <h2 class="mt-2 text-2xl font-bold text-slate-950">请输入访问码查看完整案例</h2>
    <p class="mt-2 text-slate-600">公开页面只展示概览信息。完整视频、文档和详细拆解应通过外部私有链接或签名链接访问。</p>
    <form class="mt-5 flex flex-col gap-3 sm:flex-row" data-access-form>
      <input class="min-w-0 flex-1 rounded-xl border border-slate-300 px-4 py-3 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100" type="password" name="accessCode" placeholder="Access code" autocomplete="off" />
      <button class="rounded-xl bg-blue-600 px-5 py-3 font-semibold text-white hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60" type="submit">Unlock</button>
    </form>
    <p class="mt-3 hidden text-sm text-red-600" data-access-error>访问码不正确，请检查后重试。</p>
  </div>
  <div class="hidden" data-unlocked>
    <div class="mb-5 rounded-2xl bg-emerald-50 p-4 text-sm font-medium text-emerald-800">Unlocked in this browser. Shared for recruitment evaluation only. Please do not redistribute.</div>
    <slot />
    <button class="mt-6 text-sm font-semibold text-blue-700 hover:underline" type="button" data-access-lock>Lock again</button>
  </div>
</section>
<script>
  document.querySelectorAll('[data-access-gate]').forEach((gate) => {
    const code = gate.getAttribute('data-access-code');
    const storageKey = gate.getAttribute('data-storage-key') || 'portfolio-access';
    const locked = gate.querySelector('[data-locked]');
    const unlocked = gate.querySelector('[data-unlocked]');
    const form = gate.querySelector('[data-access-form]');
    const error = gate.querySelector('[data-access-error]');
    const lockButton = gate.querySelector('[data-access-lock]');
    const setUnlocked = (value) => {
      locked?.classList.toggle('hidden', value);
      unlocked?.classList.toggle('hidden', !value);
      if (value) localStorage.setItem(storageKey, 'true');
      else localStorage.removeItem(storageKey);
    };
    setUnlocked(localStorage.getItem(storageKey) === 'true');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = new FormData(form).get('accessCode')?.toString().trim();
      if (input === code) setUnlocked(true);
      else error?.classList.remove('hidden');
    });
    lockButton?.addEventListener('click', () => setUnlocked(false));
  });
</script>
