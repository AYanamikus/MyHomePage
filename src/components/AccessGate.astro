---
const { code = 'preview-2026' } = Astro.props;
---
<section class="rounded-3xl border border-blue-100 bg-white p-6 shadow-sm" data-access-gate data-access-code={code}>
  <div data-locked>
    <h2 class="text-2xl font-bold text-slate-950">Access required</h2>
    <p class="mt-2 text-slate-600">Enter the lightweight preview code to unlock protected notes on this page.</p>
    <form class="mt-5 flex flex-col gap-3 sm:flex-row" data-access-form>
      <input class="min-w-0 flex-1 rounded-xl border border-slate-300 px-4 py-3 focus:border-brand focus:outline-none focus:ring-2 focus:ring-blue-100" type="password" name="accessCode" placeholder="Access code" autocomplete="off" />
      <button class="rounded-xl bg-brand px-5 py-3 font-semibold text-white hover:bg-blue-700" type="submit">Unlock</button>
    </form>
    <p class="mt-3 hidden text-sm text-red-600" data-access-error>Invalid access code.</p>
  </div>
  <div class="hidden" data-unlocked>
    <h2 class="text-2xl font-bold text-slate-950">Unlocked preview</h2>
    <div class="prose-lite mt-3 text-slate-600">
      <slot />
    </div>
    <button class="mt-5 text-sm font-semibold text-brand hover:underline" type="button" data-access-lock>Lock again</button>
  </div>
</section>
<script>
  const storageKey = 'my-home-page-access';
  document.querySelectorAll('[data-access-gate]').forEach((gate) => {
    const code = gate.getAttribute('data-access-code');
    const locked = gate.querySelector('[data-locked]');
    const unlocked = gate.querySelector('[data-unlocked]');
    const form = gate.querySelector('[data-access-form]');
    const error = gate.querySelector('[data-access-error]');
    const lockButton = gate.querySelector('[data-access-lock]');
    const setUnlocked = (value) => {
      locked?.classList.toggle('hidden', value);
      unlocked?.classList.toggle('hidden', !value);
      if (value) localStorage.setItem(storageKey, 'unlocked');
      else localStorage.removeItem(storageKey);
    };
    setUnlocked(localStorage.getItem(storageKey) === 'unlocked');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const input = new FormData(form).get('accessCode')?.toString().trim();
      if (input === code) setUnlocked(true);
      else error?.classList.remove('hidden');
    });
    lockButton?.addEventListener('click', () => setUnlocked(false));
  });
</script>
