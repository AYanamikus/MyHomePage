---
const { id, eyebrow, title } = Astro.props;
---
<section id={id} class="scroll-mt-24 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  {eyebrow && <p class="text-xs font-bold uppercase tracking-[0.25em] text-blue-600">{eyebrow}</p>}
  <h2 class="mt-2 text-2xl font-bold tracking-tight text-slate-950">{title}</h2>
  <div class="mt-4 space-y-3 leading-7 text-slate-650">
    <slot />
  </div>
</section>
