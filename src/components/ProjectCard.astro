---
const { title, summary, tags = [], href = '#' } = Astro.props;
---
<article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
  <h3 class="text-xl font-semibold text-slate-950">{title}</h3>
  <p class="mt-3 text-slate-600">{summary}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-brand">{tag}</span>)}
  </div>
  <a class="mt-5 inline-flex text-sm font-semibold text-brand hover:underline" href={href}>View details →</a>
</article>
