---
const { project } = Astro.props;
---
<article class="flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <div class="flex min-h-36 items-center justify-center bg-gradient-to-br from-slate-100 to-blue-50 p-5 text-center text-sm font-semibold text-slate-500">
    {project.thumbnailLabel}
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-xl font-bold text-slate-950">{project.title}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{project.shortSummary}</p>
    <dl class="mt-5 space-y-3 text-sm">
      <div><dt class="font-semibold text-slate-950">Role</dt><dd class="mt-1 text-slate-600">{project.role}</dd></div>
      <div><dt class="font-semibold text-slate-950">Tools</dt><dd class="mt-1 text-slate-600">{project.tools.join(' · ')}</dd></div>
    </dl>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.tags.map((tag) => <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">{tag}</span>)}
    </div>
    <a class="mt-6 inline-flex w-fit rounded-xl bg-slate-950 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" href={project.restrictedCaseStudyLink}>Restricted case study →</a>
  </div>
</article>
