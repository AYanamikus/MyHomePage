---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | MyHomePage">
  <section class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand">Contact</p>
    <h1 class="mt-3 text-4xl font-black text-slate-950">Start a focused conversation.</h1>
    <p class="mt-4 max-w-2xl text-lg text-slate-600">Replace these placeholders with approved contact channels before launch.</p>
    <dl class="mt-8 grid gap-4 text-slate-700 sm:grid-cols-2">
      <div class="rounded-2xl bg-slate-50 p-5">
        <dt class="font-semibold text-slate-950">Email</dt>
        <dd class="mt-1">hello@example.com</dd>
      </div>
      <div class="rounded-2xl bg-slate-50 p-5">
        <dt class="font-semibold text-slate-950">Availability</dt>
        <dd class="mt-1">Private preview by access code</dd>
      </div>
    </dl>
  </section>
</BaseLayout>
