---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---
<BaseLayout title="Home | Combat Design Portfolio">
  <section class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.3em] text-blue-700">Game Combat Designer / Technical Designer</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-6xl">面向 HR 与面试官的战斗策划作品集</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">聚焦 UE5 Action RPG 战斗原型、堆叠引爆系统、E-Mode 变身与空战、敌人与 Boss 攻击槽，以及 AI 辅助战斗设计工作流。</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded-xl bg-blue-600 px-5 py-3 font-semibold text-white hover:bg-blue-700" href="/projects">查看项目</a>
        <a class="rounded-xl border border-slate-300 bg-white px-5 py-3 font-semibold text-slate-700 hover:bg-slate-50" href="/case-studies/ue5-action-rpg-combat-prototype">重点案例</a>
      </div>
    </div>
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-bold text-slate-950">Portfolio Focus</h2>
      <ul class="mt-5 space-y-3 text-slate-600">
        <li>• 可读、可迭代的战斗循环与反馈层级</li>
        <li>• 设计文档、原型逻辑、数值表格之间的连接</li>
        <li>• 公开内容与私有材料分离，保护面试材料</li>
      </ul>
    </div>
  </section>
  <section class="mt-14">
    <div class="flex items-end justify-between gap-4">
      <div><p class="text-sm font-bold uppercase tracking-[0.25em] text-blue-700">Selected Projects</p><h2 class="mt-2 text-3xl font-black text-slate-950">项目概览</h2></div>
      <a class="text-sm font-semibold text-blue-700 hover:underline" href="/projects">全部项目 →</a>
    </div>
    <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {projects.slice(0, 3).map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
