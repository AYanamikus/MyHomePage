---
import BaseLayout from '../layouts/BaseLayout.astro';
import PrivateLinkButton from '../components/PrivateLinkButton.astro';
const docs = [
  ['Combat Design Brief', '战斗目标、核心循环、状态规则与反馈目标的摘要。', 'PRIVATE_DOCUMENT_URL'],
  ['System Spreadsheet', '堆叠、引爆、冷却、攻击槽权重等表格占位说明。', 'PRIVATE_DOCUMENT_URL'],
  ['Prototype Video', '完整视频不放入 public，应通过外部私有链接或签名链接访问。', 'PRIVATE_VIDEO_URL'],
  ['Internship Notes', '只展示可公开说明，不包含公司机密或不可验证产出。', 'PRIVATE_DOCUMENT_URL']
];
---
<BaseLayout title="Documents | Combat Design Portfolio">
  <h1 class="text-4xl font-black text-slate-950">Documents</h1>
  <p class="mt-4 max-w-3xl text-lg text-slate-600">这里只提供文档类别和说明，不直接存放完整敏感 PDF / Word / Excel / Video。完整材料应放在外部私有链接或签名链接中。</p>
  <div class="mt-8 grid gap-6 md:grid-cols-2">
    {docs.map(([title, description, href]) => (
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-950">{title}</h2>
        <p class="mt-3 text-slate-600">{description}</p>
        <div class="mt-5"><PrivateLinkButton href={href} label={href} /></div>
      </article>
    ))}
  </div>
</BaseLayout>
